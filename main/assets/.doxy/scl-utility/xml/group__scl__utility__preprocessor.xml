      <memberdef kind="define" id="group__scl__utility__preprocessor_1ga6f202c846d606a19e89b145d38288aba" prot="public" static="no">
        <name>SCL_COUNTER_VALUE</name>
        <param><defname>Tag</defname></param>
        <briefdescription>
<para>Reads the current value of a compile-time counter. </para>
        </briefdescription>
        <detaileddescription>
<para>This macro constructs the counter&apos;s value by checking for <computeroutput>crumb</computeroutput> overloads for each bit from 0 to 31. It chains <computeroutput>SCL_COUNTER_CRUMB</computeroutput> calls, where each call resolves to the most specific <computeroutput>crumb</computeroutput> function available for its rank.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>Tag</parametername>
</parameternamelist>
<parameterdescription>
<para>The unique identifier for the counter. Can be a template type. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>A <computeroutput>constexpr</computeroutput> value of type <computeroutput>std::uint_fast32_t</computeroutput>.</para>
</simplesect>
<programlisting filename=".cpp"><codeline><highlight class="keyword">template</highlight><highlight class="normal"><sp/>&lt;</highlight><highlight class="keyword">typename</highlight><highlight class="normal"><sp/>T&gt;</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">struct<sp/></highlight><highlight class="normal">TemplateTag<sp/>{};</highlight></codeline>
<codeline><highlight class="normal"><sp/></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">//<sp/>The<sp/>SCL_FORWARD<sp/>macro<sp/>is<sp/>crucial<sp/>here</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">constexpr</highlight><highlight class="normal"><sp/></highlight><highlight class="keyword">auto</highlight><highlight class="normal"><sp/>tpl_val_0<sp/>=<sp/><ref refid="group__scl__utility__preprocessor_1ga6f202c846d606a19e89b145d38288aba" kindref="member">SCL_COUNTER_VALUE</ref>(TemplateTag&lt;int&gt;);</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">static_assert</highlight><highlight class="normal">(tpl_val_0<sp/>==<sp/>0);</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="group__scl__utility__preprocessor_1gaef4b850a946910de7341123b472bdf60" kindref="member">SCL_COUNTER_NEXT</ref>(TemplateTag&lt;int&gt;)</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">constexpr</highlight><highlight class="normal"><sp/></highlight><highlight class="keyword">auto</highlight><highlight class="normal"><sp/>tpl_val_1<sp/>=<sp/><ref refid="group__scl__utility__preprocessor_1ga6f202c846d606a19e89b145d38288aba" kindref="member">SCL_COUNTER_VALUE</ref>(TemplateTag&lt;int&gt;);</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">static_assert</highlight><highlight class="normal">(tpl_val_1<sp/>==<sp/>1);</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">//<sp/>A<sp/>different<sp/>specialization<sp/>of<sp/>the<sp/>same<sp/>template<sp/>tag<sp/>should<sp/>be<sp/>a<sp/>different<sp/>counter</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">constexpr</highlight><highlight class="normal"><sp/></highlight><highlight class="keyword">auto</highlight><highlight class="normal"><sp/>tpl_val_float_0<sp/>=<sp/><ref refid="group__scl__utility__preprocessor_1ga6f202c846d606a19e89b145d38288aba" kindref="member">SCL_COUNTER_VALUE</ref>(TemplateTag&lt;float&gt;);</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">static_assert</highlight><highlight class="normal">(tpl_val_float_0<sp/>==<sp/>0);</highlight></codeline>
</programlisting> </para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
