      <memberdef kind="define" id="group__scl__utility__preprocessor_1gaef4b850a946910de7341123b472bdf60" prot="public" static="no">
        <name>SCL_COUNTER_NEXT</name>
        <param><defname>Tag</defname></param>
        <initializer>    namespace scl::preprocessor::detail                                                                \
    {                                                                                                  \
        constexpr counter&lt;<ref refid="group__scl__utility__preprocessor_1ga6f202c846d606a19e89b145d38288aba" kindref="member">SCL_COUNTER_VALUE</ref>(<ref refid="group__scl__utility__preprocessor_1ga0754b276155ba49607e834c88c2c5887" kindref="member">SCL_FORWARD</ref>(Tag)) + 1&gt; crumb(Tag,                          \
            counter&lt;(<ref refid="group__scl__utility__preprocessor_1ga6f202c846d606a19e89b145d38288aba" kindref="member">SCL_COUNTER_VALUE</ref>(<ref refid="group__scl__utility__preprocessor_1ga0754b276155ba49607e834c88c2c5887" kindref="member">SCL_FORWARD</ref>(Tag)) + 1) &amp; ~<ref refid="group__scl__utility__preprocessor_1ga6f202c846d606a19e89b145d38288aba" kindref="member">SCL_COUNTER_VALUE</ref>(<ref refid="group__scl__utility__preprocessor_1ga0754b276155ba49607e834c88c2c5887" kindref="member">SCL_FORWARD</ref>(Tag))&gt;, \
            counter&lt;(<ref refid="group__scl__utility__preprocessor_1ga6f202c846d606a19e89b145d38288aba" kindref="member">SCL_COUNTER_VALUE</ref>(<ref refid="group__scl__utility__preprocessor_1ga0754b276155ba49607e834c88c2c5887" kindref="member">SCL_FORWARD</ref>(Tag)) + 1) &amp; <ref refid="group__scl__utility__preprocessor_1ga6f202c846d606a19e89b145d38288aba" kindref="member">SCL_COUNTER_VALUE</ref>(<ref refid="group__scl__utility__preprocessor_1ga0754b276155ba49607e834c88c2c5887" kindref="member">SCL_FORWARD</ref>(Tag))&gt;)  \
        {                                                                                              \
            return {};                                                                                 \
        }                                                                                              \
    }</initializer>
        <briefdescription>
<para>Increments a compile-time counter. </para>
        </briefdescription>
        <detaileddescription>
<para>This macro defines a new <computeroutput>crumb</computeroutput> function overload in the <computeroutput>scl</computeroutput> namespace. This new function is a better match for overload resolution for a specific bit-rank, effectively &quot;setting&quot; that bit and incrementing the counter&apos;s value for subsequent reads via <computeroutput>SCL_COUNTER_VALUE</computeroutput>.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>Tag</parametername>
</parameternamelist>
<parameterdescription>
<para>The unique identifier for the counter to increment. Can be a template type.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<programlisting filename=".cpp"><codeline><highlight class="keyword">struct<sp/></highlight><highlight class="normal">MyCounterTag1<sp/>{};</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">//<sp/>The<sp/>counter<sp/>starts<sp/>at<sp/>0<sp/>before<sp/>any<sp/>increments</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">constexpr</highlight><highlight class="normal"><sp/></highlight><highlight class="keyword">auto</highlight><highlight class="normal"><sp/>val1_0<sp/>=<sp/><ref refid="group__scl__utility__preprocessor_1ga6f202c846d606a19e89b145d38288aba" kindref="member">SCL_COUNTER_VALUE</ref>(MyCounterTag1);</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">static_assert</highlight><highlight class="normal">(val1_0,<sp/>0);</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="group__scl__utility__preprocessor_1gaef4b850a946910de7341123b472bdf60" kindref="member">SCL_COUNTER_NEXT</ref>(MyCounterTag1)</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">constexpr</highlight><highlight class="normal"><sp/></highlight><highlight class="keyword">auto</highlight><highlight class="normal"><sp/>val1_1<sp/>=<sp/><ref refid="group__scl__utility__preprocessor_1ga6f202c846d606a19e89b145d38288aba" kindref="member">SCL_COUNTER_VALUE</ref>(MyCounterTag1);</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">static_assert</highlight><highlight class="normal">(val1_1,<sp/>1);</highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="group__scl__utility__preprocessor_1gaef4b850a946910de7341123b472bdf60" kindref="member">SCL_COUNTER_NEXT</ref>(MyCounterTag1)</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">constexpr</highlight><highlight class="normal"><sp/></highlight><highlight class="keyword">auto</highlight><highlight class="normal"><sp/>val1_2<sp/>=<sp/><ref refid="group__scl__utility__preprocessor_1ga6f202c846d606a19e89b145d38288aba" kindref="member">SCL_COUNTER_VALUE</ref>(MyCounterTag1);</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">static_assert</highlight><highlight class="normal">(val1_2,<sp/>2);</highlight></codeline>
</programlisting> </para>
        </detaileddescription>
